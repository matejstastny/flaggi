    {"type":"text","id":"sp_info_l","x":20,"y":460,"width":480,"height":170,"text":"Location: client/src/main/resources/sprites/\n\nAnimated (player-blue/, player-red/, etc.):\n  idle/ walk-up/ walk-down/ walk-side/ walk-diagonal/\n  Each subfolder: 0.png, 1.png, 2.png ...\n\nStatic (tree/, bullet/, flag-blue/, flag-red/):\n  Single PNG file\n\nUsage: new Sprite(\"player-blue\", 8)  // 8 FPS\n       sprite.setAnimation(\"walk-up\")\n       sprite.tick() + sprite.render(g2, x, y, root)","fontSize":14,"strokeColor":"#1e1e1e","fontFamily":1,"textAlign":"center","verticalAlign":"middle","angle":0,"backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"roundness":null,"seed":27,"groupIds":[],"frameId":null,"index":"c6","boundElements":null,"updated":1,"link":null,"locked":false,"containerId":"sp_info","originalText":"Location: client/src/main/resources/sprites/\n\nAnimated (player-blue/, player-red/, etc.):\n  idle/ walk-up/ walk-down/ walk-side/ walk-diagonal/\n  Each subfolder: 0.png, 1.png, 2.png ...\n\nStatic (tree/, bullet/, flag-blue/, flag-red/):\n  Single PNG file\n\nUsage: new Sprite(\"player-blue\", 8)  // 8 FPS\n       sprite.setAnimation(\"walk-up\")\n       sprite.tick() + sprite.render(g2, x, y, root)","autoResize":true,"lineHeight":1.25},
