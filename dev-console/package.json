{
    "name": "flaggi-dev-console",
    "productName": "Flaggi Dev Console",
    "version": "1.0.0",
    "description": "Flaggi development console",
    "main": "dist/main.js",
    "scripts": {
        "build": "npm run build:main && vite build",
        "build:main": "tsc -p tsconfig.electron.json",
        "start": "npm run build && electron .",
        "dev": "npm run build:main && electron .",
        "typecheck": "npm run typecheck:renderer && npm run typecheck:main",
        "typecheck:renderer": "tsc --noEmit -p tsconfig.json",
        "typecheck:main": "tsc --noEmit -p tsconfig.electron.json"
    },
    "dependencies": {
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@types/node": "^24.9.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@vitejs/plugin-react": "^5.1.0",
        "electron": "^41.2.2",
        "typescript": "^5.9.3",
        "vite": "^7.1.11"
    }
}
