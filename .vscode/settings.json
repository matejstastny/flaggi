{
    // Formatters ---------------------------------------------------------------

    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "[java]": {
        "editor.defaultFormatter": "richardwillis.vscode-spotless-gradle"
    },
    "[kotlin]": {
        "editor.defaultFormatter": "mskelton.ktlint"
    },
    "[proto]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        },
        "editor.semanticHighlighting.enabled": true
    },
    "[dockerfile]": {
        "editor.defaultFormatter": "ms-azuretools.vscode-containers"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "[yaml]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[astro]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[shellscript]": {
        "editor.defaultFormatter": "mkhl.shfmt"
    },

    // Java ---------------------------------------------------------------------

    "java.configuration.updateBuildConfiguration": "automatic",
    "java.debug.settings.onBuildFailureProceed": true,
    "java.compile.nullAnalysis.mode": "automatic",
    "java.import.gradle.wrapper.enabled": true,
    "java.import.gradle.enabled": true,
    "redhat.telemetry.enabled": false,
    "gradle.nestedProjects": true,

    "files.associations": {
        "*.gradle.kts": "kotlin"
    },

    // Proto --------------------------------------------------------------------

    "protobuf.protoc.path": "/usr/bin/protoc",
    "protobuf.protoc.options": [
        "--proto_path=${workspaceRoot}/shared/src/main/proto",
        "--java_out=${workspaceRoot}/shared/build/generated/sources/proto/main/java"
    ],
    "protobuf.clangFormat.configPath": "${workspaceFolder}/.clang-format",
    "protobuf.codegen.generateOnSave": true,
    "protobuf.clangFormat.enabled": true,

    // Tree exclude -------------------------------------------------------------

    "files.exclude": {
        "**/.gradle": true,
        "gradlew": true,
        "gradlew.bat": true,
        "**/build": true,
        "**/bin": true,
        "**/.kotlin": true,
        "docs/.astro": true,
        "docs/dist": true,
        "docs/node_modules": true,
        ".claude": true
    },

    // Other --------------------------------------------------------------------

    "remote.autoForwardPorts": false
}
