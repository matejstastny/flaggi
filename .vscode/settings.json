{
    // Formatters ---------------------------------------------------------------
    "editor.formatOnSave": true,
    "[java]": {
        "editor.defaultFormatter": "redhat.java",
    },
    "[dockerfile]": {
        "editor.defaultFormatter": "ms-azuretools.vscode-containers"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[xml]": {
        "editor.defaultFormatter": "DotJoshJohnson.xml"
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
    },
    // Proto --------------------------------------------------------------------
    "protoc": {
        "compile_on_save": true,
        "options": [
            "--proto_path=${workspaceRoot}/app/shared/src/main/proto",
            "--proto_path=${env.GOPATH}/src",
            "--java_out=${workspaceRoot}/app/shared/build/generated/source/proto/main/java"
        ]
    },
    // Tree exclude -------------------------------------------------------------
    "files.exclude": {
        "**/.gradle": true,
        "gradlew": true,
        "gradlew.bat": true,
        "**/build": true,
        "**/bin": true,
        "**/.kotlin": true
    },
    // Other --------------------------------------------------------------------
    "files.associations": {
        "*.gradle.kts": "kotlin",
        "*.sdkmanrc": "shellscript"
    },
    "java.format.settings.url": "./.vscode/formatter/java-formatter.xml",
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.debug.settings.onBuildFailureProceed": true,
    "java.compile.nullAnalysis.mode": "automatic",
    "java.import.gradle.wrapper.enabled": true,
    "java.import.gradle.enabled": false,
    "yaml.format.proseWrap": "never",
    "yaml.format.trailingComma": true
}
