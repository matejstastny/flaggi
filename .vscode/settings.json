{
    // Global -------------------------------------------------------------------
    "editor.formatOnSave": true,
    "[java]": {
        "editor.defaultFormatter": "redhat.java",
    },
    "[dockerfile]": {
        "editor.defaultFormatter": "ms-azuretools.vscode-containers"
    },
    "[kotlin]": {
        "editor.defaultFormatter": "fwcd.kotlin"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[xml]": {
        "editor.defaultFormatter": "DotJoshJohnson.xml"
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
    },
    // Proto --------------------------------------------------------------------
    "protoc": {
        "compile_on_save": true,
        "options": [
            "--proto_path=${workspaceRoot}/app/shared/src/main/proto",
            "--proto_path=${env.GOPATH}/src",
            "--java_out=${workspaceRoot}/app/shared/build/generated/source/proto/main/java"
        ]
    },
    // Fallback -----------------------------------------------------------------
    // In case the folder is not opened using the workspace (please don't do that)
    "java.format.settings.url": "./.vscode/formatter/java-formatter.xml",
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.debug.settings.onBuildFailureProceed": true,
    "java.compile.nullAnalysis.mode": "automatic",
    "java.import.gradle.enabled": true,
}
